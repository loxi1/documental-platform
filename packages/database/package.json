{
  "name": "@documental/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc",
    "db:migrate:verify": "pnpm build && node dist/migrations/cli.js verify",
    "test:migrations": "pnpm build && node --test dist/migrations/__tests__/*.test.js",
    "db:migrate:status": "pnpm build && node dist/migrations/cli.js status",
    "db:migrate": "pnpm build && node dist/migrations/cli.js migrate"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.0",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.9.3"
  }
}
