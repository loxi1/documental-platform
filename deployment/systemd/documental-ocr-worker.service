[Unit]
Description=Documental OCR Worker
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=loxi1
WorkingDirectory=/home/loxi1/projects/apps/documental-platform/workers/ocr-worker
EnvironmentFile=/home/loxi1/projects/apps/documental-platform/deployment/env/.env.production
Environment="PATH=/home/loxi1/projects/apps/documental-platform/workers/ocr-worker/.venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/loxi1/projects/apps/documental-platform/workers/ocr-worker/.venv/bin/python -m app.main
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
